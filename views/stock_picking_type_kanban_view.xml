<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_picking_type_kanban_redesign" model="ir.ui.view">
        <field name="name">stock.picking.type.kanban.redesign</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.stock_picking_type_kanban"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <!--
                Exponemos el campo 'code' en el kanban para que el JS
                pueda leerlo y asignar el color/icono correcto por tipo.
                Si Odoo 19 ya lo incluye en la vista base, este xpath
                simplemente no cambia nada.
            -->
            <xpath expr="//field[@name='color']" position="after">
                <field name="code" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>